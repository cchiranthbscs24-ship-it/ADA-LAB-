#include<stdio.h>
#include<math.h>

int board[20], n;

int isSafe(int row, int col)
{
    for(int i=1; i<=row; i++)
    {
        if(board[i]==col || (abs(board[i]-col) == abs(i-row)))
            return 0;
    }
    return 1;
}

void printSolution()
{
    printf("\nSolution:\n");
    for(int i=1; i<=n; i++)
    {
        for(int j=1; j<=n; j++)
        {
            if(board[i] == j)
               printf("Q");
            else
                printf(".");
        }
        printf("\n");
    }
}

void solveNQueens(int row)
{
    for(int col=1; col<=n; col++)
    {
        if(isSafe(row, col))
        {
            board[row]=col;
            if(row==n)
                printSolution();
            else
                solveNQueens(row+1);
        }
    }
}

int main()
{
    printf("Enter number of Queens:");
    scanf("%d", &n);
    solveNQueens(1);
    return 0;
}
