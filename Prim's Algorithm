#include <stdio.h>

#define INF 999

int main()
{
    int n;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    int cost[10][10];

    printf("Enter cost matrix:\n");

    for(int i = 0; i < n; i++)
    {
        for(int j = 0; j < n; j++)
        {
            scanf("%d", &cost[i][j]);

            if(cost[i][j] == 0 && i != j)
            {
                cost[i][j] = INF;
            }
        }
    }

    int visited[10] = {0};

    visited[0] = 1;

    int edges = 0;
    int minCost = 0;

    printf("\nEdges in MST:\n");

    while(edges < n - 1)
    {
        int min = INF;
        int u = -1, v = -1;

        for(int i = 0; i < n; i++)
        {
            if(visited[i])
            {
                for(int j = 0; j < n; j++)
                {
                    if(!visited[j] && cost[i][j] < min)
                    {
                        min = cost[i][j];
                        u = i;
                        v = j;
                    }
                }
            }
        }

        printf("%d -> %d = %d\n", u, v, min);

        minCost += min;

        visited[v] = 1;

        edges++;
    }

    printf("\nMinimum Cost = %d\n", minCost);

    return 0;
}
