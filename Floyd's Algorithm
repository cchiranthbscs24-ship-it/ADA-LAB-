#include<stdio.h>
#include<math.h>

int main()
{
    int i, j, n, k;
    int cost[20][20];

    printf("Enter number of vertices:");
    scanf("%d", &n);

    printf("Enter cost matrix:");
    for(i=0; i<n; i++)
    {
        for(j=0; j<n; j++)
            scanf("%d", &cost[i][j]);
    }

    for(k=0; k<n; k++)
    {
        for(i=0; i<n; i++)
        {
            for(j=0; j<n; j++)
            {
                if(cost[i][j] > cost[i][k]+cost[k][j])
                    cost[i][j] = cost[i][k]+cost[k][j];
            }
        }
    }

    printf("\nShortest path matrix:\n");
    for(i=0; i<n; i++)
    {
        for(j=0; j<n; j++)
            printf("%d\t", cost[i][j]);
        printf("\n");
    }
    return 0;
}
